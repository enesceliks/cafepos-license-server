# Ortam Değişkenleri — Railway'de bu değerleri ayarlayın
# Bu dosyayı .env olarak kopyalayın ve doldurun

# Admin paneline erişim için gizli anahtar
# MUTLAKA GÜÇLü bir şifre yazın!
ADMIN_SECRET=buraya-guclu-bir-sifre-yazin

# Sunucu portu (Railway otomatik ayarlar, değiştirmeyin)
PORT=4000

# Veritabanı yolu (Railway volume kullanıyorsa değiştirin)
# DB_PATH=/data/licenses.db
